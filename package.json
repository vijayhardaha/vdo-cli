{
  "name": "@vijayhardaha/vdo-cli",
  "version": "1.0.3",
  "description": "A Node.js CLI tool for video utilities using yt-dlp and ffmpeg",
  "type": "module",
  "main": "./dist/vdo.js",
  "bin": {
    "vdo": "dist/vdo.js"
  },
  "homepage": "https://github.com/vijayhardaha/vdo-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vijayhardaha/vdo-cli.git"
  },
  "bugs": {
    "url": "https://github.com/vijayhardaha/vdo-cli/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.mjs --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css,md,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,css,md,yml}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "tsc": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "prepare": "husky"
  },
  "keywords": [
    "video",
    "cli",
    "ffmpeg",
    "yt-dlp",
    "download",
    "convert",
    "compress",
    "audio",
    "extract"
  ],
  "author": {
    "name": "Vijay Hardaha",
    "url": "https://github.com/vijayhardaha"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "yoctocolors": "^2.1.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vijayhardaha/dev-config": "^1.0.11",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.2",
    "release-it": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "trustedDependencies": [
    "esbuild",
    "unrs-resolver"
  ]
}
